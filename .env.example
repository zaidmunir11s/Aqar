# Local backend (LAN IP so physical devices can reach your machine; omit to use production fallback in src/constants/api.ts)
EXPO_PUBLIC_API_BASE_URL=http://192.168.50.68:3000

EXPO_PUBLIC_SUPABASE_URL=<YOUR_SUPABASE_URL>
EXPO_PUBLIC_SUPABASE_KEY=<YOUR_SUPABASE_KEY>
# Public bucket for listing photos (create in Supabase → Storage; allow public read + insert for anon or authenticated uploads per your policy)
EXPO_PUBLIC_SUPABASE_LISTING_IMAGES_BUCKET=listing-images